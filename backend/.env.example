TECH_RESTORE_ATTACHMENTS_MAX_FILE_SIZE_BYTES=10485760
TECH_RESTORE_ATTACHMENTS_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf
