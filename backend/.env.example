PYTHON_VERSION=3.11.9
REPAIR_DESK_AUTH_ENABLED=true
# Bootstrap first owner invite when no users/admins exist
ADMIN_EMAIL=mattiskleinbh@gmail.com
ADMIN_NAME=Mattis Klein
ADMIN_INVITE_BOOTSTRAP=true
# Default false prevents resend spam on every redeploy when DB is reset.
# Set true only when you intentionally want startup to auto-send the bootstrap invite email.
ADMIN_INVITE_BOOTSTRAP_AUTOSEND=false
ADMIN_INVITE_ROLE=owner
ADMIN_INVITE_BOOTSTRAP_KEY=<bootstrap-resend-key>
# Optional: override invite expiry window in hours (default 72)
TECH_RESTORE_INVITE_EXPIRY_HOURS=72

# SMTP invite email delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=techrestore500@gmail.com
SMTP_PASSWORD=<gmail-app-password>
SMTP_FROM_EMAIL=techrestore500@gmail.com
SMTP_FROM_NAME=Tech Restore
SMTP_USE_SSL=false
SMTP_STARTTLS=true
SMTP_TIMEOUT_SECONDS=20

# Optional shared-password fallback mode
REPAIR_DESK_PASSWORD=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_NEW_VOICEMAIL_ALERT_TO=+18483291230
# Invite links and bootstrap owner invite URLs (desk frontend)
FRONTEND_BASE_URL=https://desk.techrestoredesk.com
# Twilio webhook/callback base (public API)
PUBLIC_API_BASE_URL=https://api.techrestoredesk.com
# Legacy fallback (discouraged): used only if vars above are unset
PUBLIC_BASE_URL=
CORS_ALLOWED_ORIGINS=
DATABASE_URL=
SECRET_KEY=

# Optional legacy compatibility keys (can be omitted)
# TECH_RESTORE_APP_ENV=production
# TECH_RESTORE_AUTH_BYPASS=0
# TECH_RESTORE_JWT_SECRET=
# TECH_RESTORE_SIGNED_URL_SECRET=
# TECH_RESTORE_CORS_ORIGINS=
# PUBLIC_WEBHOOK_BASE_URL=  # legacy alias for PUBLIC_API_BASE_URL
